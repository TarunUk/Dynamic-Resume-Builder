@model Resume_Builder.Models.ResumeModel

@{
    ViewData["Title"] = "Education";
}

<style>
    :root {
        --primary: #7C3AED;
        --primary-light: #a78bfa;
        --bg: #F1F5F9;
        --card-bg: #ffffff;
        --text-dark: #1E293B;
        --text-muted: #64748B;
        --border: #E2E8F0;
        --shadow: 0 4px 24px rgba(124,58,237,0.07);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        height: 100vh;
        overflow: hidden;
    }

    .top-header {
        height: 56px;
        background: #fff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 15px;
    }

    .brand-text h6 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--primary);
        font-size: 1rem;
    }

    .brand-text p {
        margin: 0;
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .main-layout {
        display: flex;
        height: calc(100vh - 56px);
        margin-top: 56px;
    }

    .left-panel {
        width: 48%;
        background: var(--bg);
        overflow-y: auto;
        padding: 24px;
        border-right: 1px solid var(--border);
    }

    .steps-bar {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 24px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted);
    }

        .step-circle.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .step-circle.done {
            background: #10B981;
            border-color: #10B981;
            color: #fff;
        }

    .step-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

        .step-label.active {
            color: var(--primary);
            font-weight: 600;
        }

    .step-line {
        width: 28px;
        height: 2px;
        background: var(--border);
        margin-bottom: 18px;
        flex-shrink: 0;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow);
        padding: 28px;
        margin-bottom: 16px;
    }

        .form-card h4 {
            font-family: 'Playfair Display', serif;
            color: var(--text-dark);
            margin-bottom: 4px;
            font-size: 1.2rem;
        }

        .form-card .subtitle {
            color: var(--text-muted);
            font-size: 0.83rem;
            margin-bottom: 22px;
        }

    .form-label {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 5px;
        display: block;
    }

    .form-control {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 0.85rem;
        color: var(--text-dark);
        width: 100%;
        transition: border-color 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
            outline: none;
        }

    .edu-entry {
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        background: #FAFAFA;
    }

    .edu-entry-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .edu-entry-title {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .btn-remove {
        background: #FEE2E2;
        color: #EF4444;
        border: none;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.75rem;
        cursor: pointer;
    }

    .btn-add-entry {
        width: 100%;
        padding: 11px;
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: #fff;
        color: var(--primary);
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: border-color 0.2s;
        margin-bottom: 20px;
    }

        .btn-add-entry:hover {
            border-color: var(--primary);
        }

    .row {
        display: flex;
        gap: 12px;
    }

    .col-6 {
        flex: 1;
    }

    .col-4 {
        flex: 0 0 calc(33.33% - 8px);
    }

    .mb-3 {
        margin-bottom: 12px;
    }

    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

    .step-progress {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .step-progress span {
            color: var(--primary);
            font-weight: 600;
        }

    .btn-next {
        padding: 10px 28px;
        background: linear-gradient(135deg, var(--primary), #A855F7);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(124,58,237,0.35);
    }

    .btn-back-sm {
        padding: 10px 20px;
        background: #fff;
        color: var(--text-dark);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .right-panel {
        width: 52%;
        background: #E8EDF5;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .preview-topbar {
        background: #fff;
        border-bottom: 1px solid var(--border);
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .preview-topbar-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-dark);
    }

        .preview-topbar-left i {
            color: var(--primary);
        }

    .zoom-controls {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .zoom-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resume-paper-wrap {
        padding: 24px;
        display: flex;
        justify-content: center;
    }

    .resume-paper {
        background: #fff;
        width: 100%;
        max-width: 600px;
        min-height: 800px;
        border-radius: 4px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.12);
        padding: 40px 44px;
        font-family: 'DM Sans', sans-serif;
    }

    .rv-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1E293B;
    }

    .rv-title {
        font-size: 0.95rem;
        color: var(--primary);
        font-weight: 500;
        margin-top: 2px;
    }

    .rv-contacts {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 2px solid var(--primary);
    }

    .rv-contact-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .rv-contact-item i {
            color: var(--primary);
            font-size: 11px;
        }

    .rv-section {
        margin-top: 20px;
    }

    .rv-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 8px;
        padding-bottom: 4px;
        border-bottom: 1px solid #EDE9FE;
    }

    .rv-edu-item {
        margin-bottom: 12px;
    }

    .rv-edu-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .rv-edu-degree {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-edu-school {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-edu-year {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .rv-edu-grade {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .rv-placeholder {
        font-size: 0.8rem;
        color: #CBD5E1;
        font-style: italic;
    }

    .rv-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .rv-exp-item {
        margin-bottom: 14px;
    }

    .rv-exp-header {
        display: flex;
        justify-content: space-between;
    }

    .rv-exp-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-exp-company {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-exp-date {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .rv-exp-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 4px;
        line-height: 1.5;
    }
</style>

<header class="top-header">
    <div class="brand">
        <div class="brand-icon"><i class="fa-solid fa-address-card"></i></div>
        <div class="brand-text">
            <h6>Resume Builder</h6>
            <p>Step 3 of 8 — Education</p>
        </div>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-back-sm">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>
</header>

<div class="main-layout">

    <!-- LEFT: FORM -->
    <div class="left-panel">

        <div class="steps-bar">
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Personal</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Experience</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle active">3</div><span class="step-label active">Education</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">4</div><span class="step-label">Skills</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">5</div><span class="step-label">Projects</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">6</div><span class="step-label">Certifications</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">7</div><span class="step-label">Languages</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">8</div><span class="step-label">Template</span></div>
        </div>

        <form asp-controller="Resume" asp-action="SaveEducation" method="post">

            <div class="form-card">
                <h4><i class="fa-solid fa-graduation-cap me-2" style="color:var(--primary)"></i>Education</h4>
                <p class="subtitle">Add your educational qualifications — most recent first.</p>

                <div id="eduEntries">
                    <div class="edu-entry" id="edu_0">
                        <div class="edu-entry-header">
                            <span class="edu-entry-title">Education #1</span>
                            <button type="button" class="btn-remove" onclick="removeEdu(0)">
                                <i class="fa-solid fa-trash"></i> Remove
                            </button>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label">Degree / Qualification</label>
                                <input type="text" name="Educations[0].Degree"
                                       class="form-control" placeholder="e.g. B.Tech, MBA"
                                       oninput="liveUpdate()" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Field of Study</label>
                                <input type="text" name="Educations[0].FieldOfStudy"
                                       class="form-control" placeholder="e.g. Computer Science"
                                       oninput="liveUpdate()" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">School / University</label>
                            <input type="text" name="Educations[0].School"
                                   class="form-control" placeholder="e.g. Punjab Technical University"
                                   oninput="liveUpdate()" />
                        </div>
                        <div class="row mb-3">
                            <div class="col-4">
                                <label class="form-label">Start Year</label>
                                <input type="text" name="Educations[0].StartYear"
                                       class="form-control" placeholder="e.g. 2018"
                                       oninput="liveUpdate()" />
                            </div>
                            <div class="col-4">
                                <label class="form-label">End Year</label>
                                <input type="text" name="Educations[0].EndYear"
                                       class="form-control" placeholder="e.g. 2022"
                                       oninput="liveUpdate()" />
                            </div>
                            <div class="col-4">
                                <label class="form-label">Grade / CGPA</label>
                                <input type="text" name="Educations[0].Grade"
                                       class="form-control" placeholder="e.g. 8.5 / 10"
                                       oninput="liveUpdate()" />
                            </div>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-add-entry" onclick="addEdu()">
                    <i class="fa-solid fa-plus"></i> Add Another Education
                </button>

                <div class="bottom-bar">
                    <a asp-controller="Resume" asp-action="Experience" class="btn-back-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <div class="step-progress">Step <span>3</span> of <span>8</span></div>
                    <button type="submit" class="btn-next">
                        Next <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>

        </form>
    </div>

    <!-- RIGHT: PREVIEW -->
    <div class="right-panel">
        <div class="preview-topbar">
            <div class="preview-topbar-left">
                <i class="fa-regular fa-eye"></i>
                Resume Preview — Modern Professional
            </div>
            <div class="zoom-controls">
                <button class="zoom-btn">−</button>
                <span>100%</span>
                <button class="zoom-btn">+</button>
            </div>
        </div>

        <div class="resume-paper-wrap">
            <div class="resume-paper">

                <!-- Personal from session -->
                <div class="rv-name">@Model.Personal.FullName</div>
                <div class="rv-title">@Model.Personal.ProfessionalTitle</div>
                <div class="rv-contacts">
                    @if (!string.IsNullOrEmpty(Model.Personal.Email))
                    {
                        <span class="rv-contact-item"><i class="fa-regular fa-envelope"></i> @Model.Personal.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Phone))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-phone"></i> @Model.Personal.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Location))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-location-dot"></i> @Model.Personal.Location</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Personal.Summary))
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Professional Summary</div>
                        <div class="rv-summary">@Model.Personal.Summary</div>
                    </div>
                }

                @if (Model.WorkExperiences.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Work Experience</div>
                        @foreach (var exp in Model.WorkExperiences)
                        {
                            <div class="rv-exp-item">
                                <div class="rv-exp-header">
                                    <div>
                                        <div class="rv-exp-title">@exp.JobTitle</div>
                                        <div class="rv-exp-company">@exp.Company</div>
                                    </div>
                                    <div class="rv-exp-date">
                                        @exp.StartDate — @(exp.IsCurrentJob ? "Present" : exp.EndDate)
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(exp.Description))
                                {
                                    <div class="rv-exp-desc">@exp.Description</div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Education live preview -->
                <div class="rv-section">
                    <div class="rv-section-title">Education</div>
                    <div id="rv_edu_list">
                        <span class="rv-placeholder">Your education will appear here as you type...</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function liveUpdate() {
            var entries = document.querySelectorAll('.edu-entry');
            var html = '';
            entries.forEach(function(entry) {
                var degree = entry.querySelector('input[name*="Degree"]').value;
                var field = entry.querySelector('input[name*="FieldOfStudy"]').value;
                var school = entry.querySelector('input[name*="School"]').value;
                var startYear = entry.querySelector('input[name*="StartYear"]').value;
                var endYear = entry.querySelector('input[name*="EndYear"]').value;
                var grade = entry.querySelector('input[name*="Grade"]').value;

                if (degree || school) {
                    html += '<div class="rv-edu-item">';
                    html += '<div class="rv-edu-header">';
                    html += '<div>';
                    html += '<div class="rv-edu-degree">' + (degree || '—') + (field ? ' in ' + field : '') + '</div>';
                    html += '<div class="rv-edu-school">' + (school || '—') + '</div>';
                    if (grade) html += '<div class="rv-edu-grade">Grade: ' + grade + '</div>';
                    html += '</div>';
                    html += '<div class="rv-edu-year">' + (startYear || '') + (endYear ? ' – ' + endYear : '') + '</div>';
                    html += '</div></div>';
                }
            });
            document.getElementById('rv_edu_list').innerHTML = html ||
                '<span class="rv-placeholder">Your education will appear here as you type...</span>';
        }

        function reindexEdu() {
            var entries = document.querySelectorAll('.edu-entry');
            entries.forEach(function(entry, i) {
                entry.id = 'edu_' + i;
                entry.querySelector('.edu-entry-title').textContent = 'Education #' + (i + 1);
                entry.querySelector('.btn-remove').setAttribute('onclick', 'removeEdu(' + i + ')');
                entry.querySelectorAll('input').forEach(function(el) {
                    if (el.name) el.name = el.name.replace(/\[\d+\]/, '[' + i + ']');
                });
            });
        }

        function addEdu() {
            var i = document.querySelectorAll('.edu-entry').length;
            var html = '<div class="edu-entry" id="edu_' + i + '">';
            html += '<div class="edu-entry-header">';
            html += '<span class="edu-entry-title">Education #' + (i + 1) + '</span>';
            html += '<button type="button" class="btn-remove" onclick="removeEdu(' + i + ')"><i class="fa-solid fa-trash"></i> Remove</button>';
            html += '</div>';
            html += '<div class="row mb-3">';
            html += '<div class="col-6"><label class="form-label">Degree / Qualification</label>';
            html += '<input type="text" name="Educations[' + i + '].Degree" class="form-control" placeholder="e.g. B.Tech, MBA" oninput="liveUpdate()" /></div>';
            html += '<div class="col-6"><label class="form-label">Field of Study</label>';
            html += '<input type="text" name="Educations[' + i + '].FieldOfStudy" class="form-control" placeholder="e.g. Computer Science" oninput="liveUpdate()" /></div></div>';
            html += '<div class="mb-3"><label class="form-label">School / University</label>';
            html += '<input type="text" name="Educations[' + i + '].School" class="form-control" placeholder="e.g. Punjab Technical University" oninput="liveUpdate()" /></div>';
            html += '<div class="row mb-3">';
            html += '<div class="col-4"><label class="form-label">Start Year</label>';
            html += '<input type="text" name="Educations[' + i + '].StartYear" class="form-control" placeholder="e.g. 2018" oninput="liveUpdate()" /></div>';
            html += '<div class="col-4"><label class="form-label">End Year</label>';
            html += '<input type="text" name="Educations[' + i + '].EndYear" class="form-control" placeholder="e.g. 2022" oninput="liveUpdate()" /></div>';
            html += '<div class="col-4"><label class="form-label">Grade / CGPA</label>';
            html += '<input type="text" name="Educations[' + i + '].Grade" class="form-control" placeholder="e.g. 8.5 / 10" oninput="liveUpdate()" /></div></div>';
            html += '</div>';
            document.getElementById('eduEntries').insertAdjacentHTML('beforeend', html);
        }

        function removeEdu(i) {
            var el = document.getElementById('edu_' + i);
            if (el) { el.remove(); reindexEdu(); liveUpdate(); }
        }


        // ← ADD THIS AT THE BOTTOM before </script>
            window.onload = function() {
                var savedEdus = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Educations ?? new List<Resume_Builder.Models.Education>()));

                if (savedEdus && savedEdus.length > 0) {
                    document.getElementById('eduEntries').innerHTML = '';
                    savedEdus.forEach(function(edu, i) {
                        var html = buildEduHtml(i);
                        document.getElementById('eduEntries').insertAdjacentHTML('beforeend', html);
                        var entry = document.getElementById('edu_' + i);
                        entry.querySelector('input[name*="Degree"]').value = edu.Degree || '';
                        entry.querySelector('input[name*="FieldOfStudy"]').value = edu.FieldOfStudy || '';
                        entry.querySelector('input[name*="School"]').value = edu.School || '';
                        entry.querySelector('input[name*="StartYear"]').value = edu.StartYear || '';
                        entry.querySelector('input[name*="EndYear"]').value = edu.EndYear || '';
                        entry.querySelector('input[name*="Grade"]').value = edu.Grade || '';
                    });
                    liveUpdate();
                }
           }

     </script>
}