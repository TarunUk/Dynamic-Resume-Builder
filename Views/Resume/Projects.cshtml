@model Resume_Builder.Models.ResumeModel

@{
    ViewData["Title"] = "Projects";
}

<style>
    :root {
        --primary: #7C3AED;
        --primary-light: #a78bfa;
        --bg: #F1F5F9;
        --card-bg: #ffffff;
        --text-dark: #1E293B;
        --text-muted: #64748B;
        --border: #E2E8F0;
        --shadow: 0 4px 24px rgba(124,58,237,0.07);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        height: 100vh;
        overflow: hidden;
    }

    .top-header {
        height: 56px;
        background: #fff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 15px;
    }

    .brand-text h6 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--primary);
        font-size: 1rem;
    }

    .brand-text p {
        margin: 0;
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .main-layout {
        display: flex;
        height: calc(100vh - 56px);
        margin-top: 56px;
    }

    .left-panel {
        width: 48%;
        background: var(--bg);
        overflow-y: auto;
        padding: 24px;
        border-right: 1px solid var(--border);
    }

    .steps-bar {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 24px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted);
    }

        .step-circle.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .step-circle.done {
            background: #10B981;
            border-color: #10B981;
            color: #fff;
        }

    .step-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

        .step-label.active {
            color: var(--primary);
            font-weight: 600;
        }

    .step-line {
        width: 28px;
        height: 2px;
        background: var(--border);
        margin-bottom: 18px;
        flex-shrink: 0;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow);
        padding: 28px;
        margin-bottom: 16px;
    }

        .form-card h4 {
            font-family: 'Playfair Display', serif;
            color: var(--text-dark);
            margin-bottom: 4px;
            font-size: 1.2rem;
        }

        .form-card .subtitle {
            color: var(--text-muted);
            font-size: 0.83rem;
            margin-bottom: 22px;
        }

    .form-label {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 5px;
        display: block;
    }

    .form-control {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 0.85rem;
        color: var(--text-dark);
        width: 100%;
        transition: border-color 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
            outline: none;
        }

    .proj-entry {
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        background: #FAFAFA;
    }

    .proj-entry-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .proj-entry-title {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .btn-remove {
        background: #FEE2E2;
        color: #EF4444;
        border: none;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 0.75rem;
        cursor: pointer;
    }

    .btn-add-entry {
        width: 100%;
        padding: 11px;
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: #fff;
        color: var(--primary);
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: border-color 0.2s;
        margin-bottom: 20px;
    }

        .btn-add-entry:hover {
            border-color: var(--primary);
        }

    .row {
        display: flex;
        gap: 12px;
    }

    .col-6 {
        flex: 1;
    }

    .mb-3 {
        margin-bottom: 12px;
    }

    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

    .step-progress {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .step-progress span {
            color: var(--primary);
            font-weight: 600;
        }

    .btn-next {
        padding: 10px 28px;
        background: linear-gradient(135deg, var(--primary), #A855F7);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(124,58,237,0.35);
    }

    .btn-back-sm {
        padding: 10px 20px;
        background: #fff;
        color: var(--text-dark);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .right-panel {
        width: 52%;
        background: #E8EDF5;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .preview-topbar {
        background: #fff;
        border-bottom: 1px solid var(--border);
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .preview-topbar-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-dark);
    }

        .preview-topbar-left i {
            color: var(--primary);
        }

    .zoom-controls {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .zoom-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resume-paper-wrap {
        padding: 24px;
        display: flex;
        justify-content: center;
    }

    .resume-paper {
        background: #fff;
        width: 100%;
        max-width: 600px;
        min-height: 800px;
        border-radius: 4px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.12);
        padding: 40px 44px;
        font-family: 'DM Sans', sans-serif;
    }

    .rv-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1E293B;
    }

    .rv-title {
        font-size: 0.95rem;
        color: var(--primary);
        font-weight: 500;
        margin-top: 2px;
    }

    .rv-contacts {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 2px solid var(--primary);
    }

    .rv-contact-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .rv-contact-item i {
            color: var(--primary);
            font-size: 11px;
        }

    .rv-section {
        margin-top: 20px;
    }

    .rv-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 8px;
        padding-bottom: 4px;
        border-bottom: 1px solid #EDE9FE;
    }

    .rv-proj-item {
        margin-bottom: 14px;
    }

    .rv-proj-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-proj-tech {
        font-size: 0.75rem;
        color: var(--primary);
        margin-top: 2px;
    }

    .rv-proj-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 4px;
        line-height: 1.5;
    }

    .rv-proj-link {
        font-size: 0.75rem;
        color: #3B82F6;
        margin-top: 3px;
    }

    .rv-placeholder {
        font-size: 0.8rem;
        color: #CBD5E1;
        font-style: italic;
    }

    .rv-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .rv-skills-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .rv-skill-tag {
        background: #EDE9FE;
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
    }
</style>

<header class="top-header">
    <div class="brand">
        <div class="brand-icon"><i class="fa-solid fa-address-card"></i></div>
        <div class="brand-text">
            <h6>Resume Builder</h6>
            <p>Step 5 of 8 — Projects</p>
        </div>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-back-sm">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>
</header>

<div class="main-layout">

    <!-- LEFT: FORM -->
    <div class="left-panel">

        <div class="steps-bar">
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Personal</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Experience</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Education</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Skills</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle active">5</div><span class="step-label active">Projects</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">6</div><span class="step-label">Certifications</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">7</div><span class="step-label">Languages</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">8</div><span class="step-label">Template</span></div>
        </div>

        <form asp-controller="Resume" asp-action="SaveProjects" method="post">

            <div class="form-card">
                <h4><i class="fa-solid fa-diagram-project me-2" style="color:var(--primary)"></i>Projects</h4>
                <p class="subtitle">Showcase your best projects — personal, academic or professional.</p>

                <div id="projEntries">
                    <div class="proj-entry" id="proj_0">
                        <div class="proj-entry-header">
                            <span class="proj-entry-title">Project #1</span>
                            <button type="button" class="btn-remove" onclick="removeProj(0)">
                                <i class="fa-solid fa-trash"></i> Remove
                            </button>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Project Title</label>
                            <input type="text" name="Projects[0].Title"
                                   class="form-control" placeholder="e.g. Resume Builder App"
                                   oninput="liveUpdate()" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tech Stack Used</label>
                            <input type="text" name="Projects[0].TechStack"
                                   class="form-control" placeholder="e.g. ASP.NET Core, Bootstrap, SQL"
                                   oninput="liveUpdate()" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Projects[0].Description"
                                      class="form-control" rows="3"
                                      placeholder="Describe what the project does and your role..."
                                      oninput="liveUpdate()"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Project Link (optional)</label>
                            <input type="text" name="Projects[0].Link"
                                   class="form-control" placeholder="e.g. github.com/yourname/project"
                                   oninput="liveUpdate()" />
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-add-entry" onclick="addProj()">
                    <i class="fa-solid fa-plus"></i> Add Another Project
                </button>

                <div class="bottom-bar">
                    <a asp-controller="Resume" asp-action="Skills" class="btn-back-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <div class="step-progress">Step <span>5</span> of <span>8</span></div>
                    <button type="submit" class="btn-next">
                        Next <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>

            </div>

        </form>
    </div>

    <!-- RIGHT: PREVIEW -->
    <div class="right-panel">
        <div class="preview-topbar">
            <div class="preview-topbar-left">
                <i class="fa-regular fa-eye"></i>
                Resume Preview — Modern Professional
            </div>
            <div class="zoom-controls">
                <button class="zoom-btn">−</button>
                <span>100%</span>
                <button class="zoom-btn">+</button>
            </div>
        </div>

        <div class="resume-paper-wrap">
            <div class="resume-paper">

                <div class="rv-name">@Model.Personal.FullName</div>
                <div class="rv-title">@Model.Personal.ProfessionalTitle</div>
                <div class="rv-contacts">
                    @if (!string.IsNullOrEmpty(Model.Personal.Email))
                    {
                        <span class="rv-contact-item"><i class="fa-regular fa-envelope"></i> @Model.Personal.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Phone))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-phone"></i> @Model.Personal.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Location))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-location-dot"></i> @Model.Personal.Location</span>
                    }
                </div>

                @if (Model.Skills.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Skills</div>
                        <div class="rv-skills-wrap">
                            @foreach (var skill in Model.Skills)
                            {
                                <span class="rv-skill-tag">@skill</span>
                            }
                        </div>
                    </div>
                }

                <!-- Projects live preview -->
                <div class="rv-section">
                    <div class="rv-section-title">Projects</div>
                    <div id="rv_proj_list">
                        <span class="rv-placeholder">Your projects will appear here as you type...</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function liveUpdate() {
            var entries = document.querySelectorAll('.proj-entry');
            var html = '';
            entries.forEach(function(entry) {
                var title = entry.querySelector('input[name*="Title"]').value;
                var tech = entry.querySelector('input[name*="TechStack"]').value;
                var desc = entry.querySelector('textarea').value;
                var link = entry.querySelector('input[name*="Link"]').value;

                if (title) {
                    html += '<div class="rv-proj-item">';
                    html += '<div class="rv-proj-title">' + title + '</div>';
                    if (tech) html += '<div class="rv-proj-tech"><i class="fa-solid fa-code" style="font-size:10px"></i> ' + tech + '</div>';
                    if (desc) html += '<div class="rv-proj-desc">' + desc + '</div>';
                    if (link) html += '<div class="rv-proj-link"><i class="fa-solid fa-link" style="font-size:10px"></i> ' + link + '</div>';
                    html += '</div>';
                }
            });
            document.getElementById('rv_proj_list').innerHTML = html ||
                '<span class="rv-placeholder">Your projects will appear here as you type...</span>';
        }

        function reindexProj() {
            var entries = document.querySelectorAll('.proj-entry');
            entries.forEach(function(entry, i) {
                entry.id = 'proj_' + i;
                entry.querySelector('.proj-entry-title').textContent = 'Project #' + (i + 1);
                entry.querySelector('.btn-remove').setAttribute('onclick', 'removeProj(' + i + ')');
                entry.querySelectorAll('input, textarea').forEach(function(el) {
                    if (el.name) el.name = el.name.replace(/\[\d+\]/, '[' + i + ']');
                });
            });
        }

        function addProj() {
            var i = document.querySelectorAll('.proj-entry').length;
            var html = '<div class="proj-entry" id="proj_' + i + '">';
            html += '<div class="proj-entry-header">';
            html += '<span class="proj-entry-title">Project #' + (i + 1) + '</span>';
            html += '<button type="button" class="btn-remove" onclick="removeProj(' + i + ')"><i class="fa-solid fa-trash"></i> Remove</button>';
            html += '</div>';
            html += '<div class="mb-3"><label class="form-label">Project Title</label>';
            html += '<input type="text" name="Projects[' + i + '].Title" class="form-control" placeholder="e.g. Resume Builder App" oninput="liveUpdate()" /></div>';
            html += '<div class="mb-3"><label class="form-label">Tech Stack Used</label>';
            html += '<input type="text" name="Projects[' + i + '].TechStack" class="form-control" placeholder="e.g. ASP.NET Core, Bootstrap" oninput="liveUpdate()" /></div>';
            html += '<div class="mb-3"><label class="form-label">Description</label>';
            html += '<textarea name="Projects[' + i + '].Description" class="form-control" rows="3" placeholder="Describe the project..." oninput="liveUpdate()"></textarea></div>';
            html += '<div class="mb-3"><label class="form-label">Project Link (optional)</label>';
            html += '<input type="text" name="Projects[' + i + '].Link" class="form-control" placeholder="e.g. github.com/yourname/project" oninput="liveUpdate()" /></div>';
            html += '</div>';
            document.getElementById('projEntries').insertAdjacentHTML('beforeend', html);
        }

        function removeProj(i) {
            var el = document.getElementById('proj_' + i);
            if (el) { el.remove(); reindexProj(); liveUpdate(); }
        }

                window.onload = function() {
            var savedProjs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Projects ?? new List<Resume_Builder.Models.Project>()));

            if (savedProjs && savedProjs.length > 0) {
                document.getElementById('projEntries').innerHTML = '';
                savedProjs.forEach(function(proj, i) {
                    addProj();
                    var entry = document.getElementById('proj_' + i);
                    entry.querySelector('input[name*="Title"]').value = proj.Title || '';
                    entry.querySelector('input[name*="TechStack"]').value = proj.TechStack || '';
                    entry.querySelector('textarea').value = proj.Description || '';
                    entry.querySelector('input[name*="Link"]').value = proj.Link || '';
                });
                liveUpdate();
            }
        }
    </script>
}