@model Resume_Builder.Models.ResumeModel

@{
    ViewData["Title"] = "Skills";
}

<style>
    :root {
        --primary: #7C3AED;
        --primary-light: #a78bfa;
        --bg: #F1F5F9;
        --card-bg: #ffffff;
        --text-dark: #1E293B;
        --text-muted: #64748B;
        --border: #E2E8F0;
        --shadow: 0 4px 24px rgba(124,58,237,0.07);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        height: 100vh;
        overflow: hidden;
    }

    .top-header {
        height: 56px;
        background: #fff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 15px;
    }

    .brand-text h6 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--primary);
        font-size: 1rem;
    }

    .brand-text p {
        margin: 0;
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .main-layout {
        display: flex;
        height: calc(100vh - 56px);
        margin-top: 56px;
    }

    .left-panel {
        width: 48%;
        background: var(--bg);
        overflow-y: auto;
        padding: 24px;
        border-right: 1px solid var(--border);
    }

    .steps-bar {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 24px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted);
    }

        .step-circle.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .step-circle.done {
            background: #10B981;
            border-color: #10B981;
            color: #fff;
        }

    .step-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

        .step-label.active {
            color: var(--primary);
            font-weight: 600;
        }

    .step-line {
        width: 28px;
        height: 2px;
        background: var(--border);
        margin-bottom: 18px;
        flex-shrink: 0;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow);
        padding: 28px;
        margin-bottom: 16px;
    }

        .form-card h4 {
            font-family: 'Playfair Display', serif;
            color: var(--text-dark);
            margin-bottom: 4px;
            font-size: 1.2rem;
        }

        .form-card .subtitle {
            color: var(--text-muted);
            font-size: 0.83rem;
            margin-bottom: 22px;
        }

    .form-label {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-dark);
        margin-bottom: 5px;
        display: block;
    }

    .form-control {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 0.85rem;
        color: var(--text-dark);
        width: 100%;
        transition: border-color 0.2s;
        font-family: 'DM Sans', sans-serif;
    }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
            outline: none;
        }

    /* Skills input area */
    .skills-input-wrap {
        position: relative;
        margin-bottom: 16px;
    }

        .skills-input-wrap input {
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 0.85rem;
            width: 100%;
            font-family: 'DM Sans', sans-serif;
        }

            .skills-input-wrap input:focus {
                border-color: var(--primary);
                outline: none;
                box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
            }

    .skills-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 16px;
        min-height: 40px;
    }

    .skill-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #EDE9FE;
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 500;
    }

        .skill-tag button {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--primary);
            font-size: 12px;
            padding: 0;
            display: flex;
            align-items: center;
        }

    .suggested-skills {
        margin-bottom: 20px;
    }

    .suggested-title {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

    .suggested-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .suggested-tag {
        padding: 5px 12px;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: 0.78rem;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.15s;
    }

        .suggested-tag:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: #EDE9FE;
        }

    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

    .step-progress {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .step-progress span {
            color: var(--primary);
            font-weight: 600;
        }

    .btn-next {
        padding: 10px 28px;
        background: linear-gradient(135deg, var(--primary), #A855F7);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(124,58,237,0.35);
    }

    .btn-back-sm {
        padding: 10px 20px;
        background: #fff;
        color: var(--text-dark);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .right-panel {
        width: 52%;
        background: #E8EDF5;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .preview-topbar {
        background: #fff;
        border-bottom: 1px solid var(--border);
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .preview-topbar-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-dark);
    }

        .preview-topbar-left i {
            color: var(--primary);
        }

    .zoom-controls {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .zoom-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resume-paper-wrap {
        padding: 24px;
        display: flex;
        justify-content: center;
    }

    .resume-paper {
        background: #fff;
        width: 100%;
        max-width: 600px;
        min-height: 800px;
        border-radius: 4px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.12);
        padding: 40px 44px;
        font-family: 'DM Sans', sans-serif;
    }

    .rv-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1E293B;
    }

    .rv-title {
        font-size: 0.95rem;
        color: var(--primary);
        font-weight: 500;
        margin-top: 2px;
    }

    .rv-contacts {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 2px solid var(--primary);
    }

    .rv-contact-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .rv-contact-item i {
            color: var(--primary);
            font-size: 11px;
        }

    .rv-section {
        margin-top: 20px;
    }

    .rv-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 8px;
        padding-bottom: 4px;
        border-bottom: 1px solid #EDE9FE;
    }

    .rv-skills-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .rv-skill-tag {
        background: #EDE9FE;
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .rv-placeholder {
        font-size: 0.8rem;
        color: #CBD5E1;
        font-style: italic;
    }

    .rv-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .rv-exp-item {
        margin-bottom: 14px;
    }

    .rv-exp-header {
        display: flex;
        justify-content: space-between;
    }

    .rv-exp-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-exp-company {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-exp-date {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .rv-exp-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 4px;
        line-height: 1.5;
    }

    .rv-edu-item {
        margin-bottom: 12px;
    }

    .rv-edu-header {
        display: flex;
        justify-content: space-between;
    }

    .rv-edu-degree {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-edu-school {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-edu-year {
        font-size: 0.75rem;
        color: var(--text-muted);
    }
</style>

<header class="top-header">
    <div class="brand">
        <div class="brand-icon"><i class="fa-solid fa-address-card"></i></div>
        <div class="brand-text">
            <h6>Resume Builder</h6>
            <p>Step 4 of 8 — Skills</p>
        </div>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-back-sm">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>
</header>

<div class="main-layout">

    <!-- LEFT: FORM -->
    <div class="left-panel">

        <div class="steps-bar">
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Personal</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Experience</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Education</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle active">4</div><span class="step-label active">Skills</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">5</div><span class="step-label">Projects</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">6</div><span class="step-label">Certifications</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">7</div><span class="step-label">Languages</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle">8</div><span class="step-label">Template</span></div>
        </div>

        <form asp-controller="Resume" asp-action="SaveSkills" method="post">

            <div class="form-card">
                <h4><i class="fa-solid fa-code me-2" style="color:var(--primary)"></i>Skills</h4>
                <p class="subtitle">Add your technical and soft skills — press Enter or comma to add each skill.</p>

                <!-- Tags display -->
                <div class="skills-tags" id="skillTags"></div>

                <!-- Hidden input to submit -->
                <input type="hidden" name="skillsInput" id="skillsInput" value="@string.Join(",", Model.Skills)" />

                <!-- Skill input -->
                <div class="skills-input-wrap">
                    <input type="text" id="skillEntry"
                           placeholder="Type a skill and press Enter or comma..."
                           onkeydown="handleSkillKey(event)" />
                </div>

                <!-- Suggested Skills -->
                <div class="suggested-skills">
                    <div class="suggested-title">Suggested skills — click to add:</div>
                    <div class="suggested-tags">
                        <span class="suggested-tag" onclick="addSuggested('JavaScript')">JavaScript</span>
                        <span class="suggested-tag" onclick="addSuggested('C#')">C#</span>
                        <span class="suggested-tag" onclick="addSuggested('ASP.NET Core')">ASP.NET Core</span>
                        <span class="suggested-tag" onclick="addSuggested('Python')">Python</span>
                        <span class="suggested-tag" onclick="addSuggested('SQL')">SQL</span>
                        <span class="suggested-tag" onclick="addSuggested('React')">React</span>
                        <span class="suggested-tag" onclick="addSuggested('Bootstrap')">Bootstrap</span>
                        <span class="suggested-tag" onclick="addSuggested('Git')">Git</span>
                        <span class="suggested-tag" onclick="addSuggested('HTML/CSS')">HTML/CSS</span>
                        <span class="suggested-tag" onclick="addSuggested('Communication')">Communication</span>
                        <span class="suggested-tag" onclick="addSuggested('Team Leadership')">Team Leadership</span>
                        <span class="suggested-tag" onclick="addSuggested('Problem Solving')">Problem Solving</span>
                    </div>
                </div>

                <div class="bottom-bar">
                    <a asp-controller="Resume" asp-action="Education" class="btn-back-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <div class="step-progress">Step <span>4</span> of <span>8</span></div>
                    <button type="submit" class="btn-next">
                        Next <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>

            </div>

        </form>
    </div>

    <!-- RIGHT: PREVIEW -->
    <div class="right-panel">
        <div class="preview-topbar">
            <div class="preview-topbar-left">
                <i class="fa-regular fa-eye"></i>
                Resume Preview — Modern Professional
            </div>
            <div class="zoom-controls">
                <button class="zoom-btn">−</button>
                <span>100%</span>
                <button class="zoom-btn">+</button>
            </div>
        </div>

        <div class="resume-paper-wrap">
            <div class="resume-paper">

                <div class="rv-name">@Model.Personal.FullName</div>
                <div class="rv-title">@Model.Personal.ProfessionalTitle</div>
                <div class="rv-contacts">
                    @if (!string.IsNullOrEmpty(Model.Personal.Email))
                    {
                        <span class="rv-contact-item"><i class="fa-regular fa-envelope"></i> @Model.Personal.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Phone))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-phone"></i> @Model.Personal.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Location))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-location-dot"></i> @Model.Personal.Location</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Personal.Summary))
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Professional Summary</div>
                        <div class="rv-summary">@Model.Personal.Summary</div>
                    </div>
                }

                @if (Model.WorkExperiences.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Work Experience</div>
                        @foreach (var exp in Model.WorkExperiences)
                        {
                            <div class="rv-exp-item">
                                <div class="rv-exp-header">
                                    <div>
                                        <div class="rv-exp-title">@exp.JobTitle</div>
                                        <div class="rv-exp-company">@exp.Company</div>
                                    </div>
                                    <div class="rv-exp-date">@exp.StartDate — @(exp.IsCurrentJob ? "Present" : exp.EndDate)</div>
                                </div>
                                @if (!string.IsNullOrEmpty(exp.Description))
                                {
                                    <div class="rv-exp-desc">@exp.Description</div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (Model.Educations.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Education</div>
                        @foreach (var edu in Model.Educations)
                        {
                            <div class="rv-edu-item">
                                <div class="rv-edu-header">
                                    <div>
                                        <div class="rv-edu-degree">@edu.Degree @(!string.IsNullOrEmpty(edu.FieldOfStudy) ? "in " + edu.FieldOfStudy : "")</div>
                                        <div class="rv-edu-school">@edu.School</div>
                                    </div>
                                    <div class="rv-edu-year">@edu.StartYear — @edu.EndYear</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Skills live preview -->
                <div class="rv-section">
                    <div class="rv-section-title">Skills</div>
                    <div class="rv-skills-wrap" id="rv_skills">
                        <span class="rv-placeholder">Your skills will appear here as you add them...</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var skills = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(Model.Skills)
            );

    function renderTags() {
        var container = document.getElementById('skillTags');
        container.innerHTML = '';
        skills.forEach(function(skill, i) {
            var tag = document.createElement('span');
            tag.className = 'skill-tag';
            tag.innerHTML = skill +
                '<button type="button" onclick="removeSkill(' + i + ')"><i class="fa-solid fa-xmark"></i></button>';
            container.appendChild(tag);
        });
        document.getElementById('skillsInput').value = skills.join(',');
        liveUpdate();
    }

        function handleSkillKey(e) {
            if (e.key === 'Enter' || e.key === ',') {
                e.preventDefault();
                var val = document.getElementById('skillEntry').value.replace(',', '').trim();
                if (val && !skills.includes(val)) {
                    skills.push(val);
                    renderTags();
                }
                document.getElementById('skillEntry').value = '';
            }
        }

        function addSuggested(skill) {
            if (!skills.includes(skill)) {
                skills.push(skill);
                renderTags();
            }
        }

        function removeSkill(i) {
            skills.splice(i, 1);
            renderTags();
        }

        function liveUpdate() {
            var container = document.getElementById('rv_skills');
            if (skills.length === 0) {
                container.innerHTML = '<span class="rv-placeholder">Your skills will appear here as you add them...</span>';
                return;
            }
            container.innerHTML = skills.map(function(s) {
                return '<span class="rv-skill-tag">' + s + '</span>';
            }).join('');
        }

        window.onload = function() { renderTags(); }
    </script>
}