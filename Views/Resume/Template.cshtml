@model Resume_Builder.Models.ResumeModel

@{
    ViewData["Title"] = "Choose Template";
}

<style>
    :root {
        --primary: #7C3AED;
        --primary-light: #a78bfa;
        --bg: #F1F5F9;
        --text-dark: #1E293B;
        --text-muted: #64748B;
        --border: #E2E8F0;
        --shadow: 0 4px 24px rgba(124,58,237,0.07);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        height: 100vh;
        overflow: hidden;
    }

    .top-header {
        height: 56px;
        background: #fff;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 15px;
    }

    .brand-text h6 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--primary);
        font-size: 1rem;
    }

    .brand-text p {
        margin: 0;
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .main-layout {
        display: flex;
        height: calc(100vh - 56px);
        margin-top: 56px;
    }

    .left-panel {
        width: 48%;
        background: var(--bg);
        overflow-y: auto;
        padding: 24px;
        border-right: 1px solid var(--border);
    }

    .steps-bar {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 24px;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 2px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-muted);
    }

        .step-circle.active {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .step-circle.done {
            background: #10B981;
            border-color: #10B981;
            color: #fff;
        }

    .step-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

        .step-label.active {
            color: var(--primary);
            font-weight: 600;
        }

    .step-line {
        width: 28px;
        height: 2px;
        background: var(--border);
        margin-bottom: 18px;
        flex-shrink: 0;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--shadow);
        padding: 28px;
    }

        .form-card h4 {
            font-family: 'Playfair Display', serif;
            color: var(--text-dark);
            margin-bottom: 4px;
            font-size: 1.2rem;
        }

        .form-card .subtitle {
            color: var(--text-muted);
            font-size: 0.83rem;
            margin-bottom: 22px;
        }

    /* Template grid */
    .template-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }

    .template-card {
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.2s;
        background: #fff;
        text-align: center;
        position: relative;
    }

        .template-card:hover {
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .template-card.selected {
            border-color: var(--primary);
            background: #EDE9FE;
        }

            .template-card.selected .check-badge {
                display: flex;
            }

    .check-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--primary);
        color: #fff;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 10px;
    }

    .template-thumb {
        width: 100%;
        height: 80px;
        border-radius: 6px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .template-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .template-tag {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 3px;
    }

    /* Template colors */
    .t-modern {
        background: linear-gradient(135deg, #EDE9FE, #DDD6FE);
    }

    .t-blue {
        background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
    }

    .t-creative {
        background: linear-gradient(135deg, #FCE7F3, #FBCFE8);
    }

    .t-executive {
        background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
    }

    .t-minimal {
        background: linear-gradient(135deg, #F0FDF4, #DCFCE7);
    }

    .t-academic {
        background: linear-gradient(135deg, #FEF3C7, #FDE68A);
    }

    .t-bold {
        background: linear-gradient(135deg, #FEE2E2, #FECACA);
    }

    .t-elegant {
        background: linear-gradient(135deg, #F5F3FF, #EDE9FE);
    }

    .bottom-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

    .step-progress {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .step-progress span {
            color: var(--primary);
            font-weight: 600;
        }

    .btn-finish {
        padding: 10px 28px;
        background: linear-gradient(135deg, #10B981, #059669);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(16,185,129,0.35);
    }

    .btn-back-sm {
        padding: 10px 20px;
        background: #fff;
        color: var(--text-dark);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .right-panel {
        width: 52%;
        background: #E8EDF5;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .preview-topbar {
        background: #fff;
        border-bottom: 1px solid var(--border);
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .preview-topbar-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-dark);
    }

        .preview-topbar-left i {
            color: var(--primary);
        }

    .zoom-controls {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .zoom-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .resume-paper-wrap {
        padding: 24px;
        display: flex;
        justify-content: center;
    }

    .resume-paper {
        background: #fff;
        width: 100%;
        max-width: 600px;
        min-height: 800px;
        border-radius: 4px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.12);
        padding: 40px 44px;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s;
    }

    .rv-name {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1E293B;
    }

    .rv-title {
        font-size: 0.95rem;
        color: var(--primary);
        font-weight: 500;
        margin-top: 2px;
    }

    .rv-contacts {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 2px solid var(--primary);
    }

    .rv-contact-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        color: var(--text-muted);
    }

        .rv-contact-item i {
            color: var(--primary);
            font-size: 11px;
        }

    .rv-section {
        margin-top: 20px;
    }

    .rv-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 8px;
        padding-bottom: 4px;
        border-bottom: 1px solid #EDE9FE;
    }

    .rv-skills-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .rv-skill-tag {
        background: #EDE9FE;
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .rv-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .rv-exp-item {
        margin-bottom: 14px;
    }

    .rv-exp-header {
        display: flex;
        justify-content: space-between;
    }

    .rv-exp-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-exp-company {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-exp-date {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .rv-exp-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 4px;
        line-height: 1.5;
    }

    .rv-edu-item {
        margin-bottom: 12px;
    }

    .rv-edu-header {
        display: flex;
        justify-content: space-between;
    }

    .rv-edu-degree {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-edu-school {
        font-size: 0.82rem;
        color: var(--primary);
    }

    .rv-edu-year {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .rv-lang-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .rv-lang-item {
        background: #F8FAFC;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 6px 12px;
    }

    .rv-lang-name {
        font-size: 0.82rem;
        font-weight: 600;
        color: #1E293B;
    }

    .rv-lang-prof {
        font-size: 0.7rem;
        color: var(--primary);
    }
</style>

<header class="top-header">
    <div class="brand">
        <div class="brand-icon"><i class="fa-solid fa-address-card"></i></div>
        <div class="brand-text">
            <h6>Resume Builder</h6>
            <p>Step 8 of 8 — Choose Template</p>
        </div>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn-back-sm">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>
</header>

<div class="main-layout">

    <!-- LEFT: FORM -->
    <div class="left-panel">

        <div class="steps-bar">
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Personal</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Experience</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Education</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Skills</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Projects</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Certifications</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle done"><i class="fa-solid fa-check" style="font-size:10px"></i></div><span class="step-label">Languages</span></div>
            <div class="step-line"></div>
            <div class="step-item"><div class="step-circle active">8</div><span class="step-label active">Template</span></div>
        </div>

        <form asp-controller="Resume" asp-action="SaveTemplate" method="post">
            <input type="hidden" name="selectedTemplate" id="selectedTemplate" value="ModernProfessional" />

            <div class="form-card">
                <h4><i class="fa-solid fa-palette me-2" style="color:var(--primary)"></i>Choose Template</h4>
                <p class="subtitle">Select a template for your resume — click to preview on the right.</p>

                <div class="template-grid">

                    <div class="template-card selected" onclick="selectTemplate('ModernProfessional', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-modern">🎯</div>
                        <div class="template-name">Modern Professional</div>
                        <div class="template-tag">Professional</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('ProfessionalBlue', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-blue">💼</div>
                        <div class="template-name">Professional Blue</div>
                        <div class="template-tag">Corporate</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('CreativeDesigner', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-creative">🎨</div>
                        <div class="template-name">Creative Designer</div>
                        <div class="template-tag">Creative</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('ExecutiveClassic', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-executive">👔</div>
                        <div class="template-name">Executive Classic</div>
                        <div class="template-tag">Executive</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('MinimalClean', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-minimal">✨</div>
                        <div class="template-name">Minimal Clean</div>
                        <div class="template-tag">Minimal</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('AcademicScholar', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-academic">🎓</div>
                        <div class="template-name">Academic Scholar</div>
                        <div class="template-tag">Academic</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('BoldImpact', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-bold">⚡</div>
                        <div class="template-name">Bold Impact</div>
                        <div class="template-tag">Creative</div>
                    </div>

                    <div class="template-card" onclick="selectTemplate('ElegantClassic', this)">
                        <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                        <div class="template-thumb t-elegant">💎</div>
                        <div class="template-name">Elegant Classic</div>
                        <div class="template-tag">Professional</div>
                    </div>

                </div>

                <div class="bottom-bar">
                    <a asp-controller="Resume" asp-action="Languages" class="btn-back-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <div class="step-progress">Step <span>8</span> of <span>8</span></div>
                    <button type="submit" class="btn-finish">
                        <i class="fa-solid fa-eye"></i> View Resume
                    </button>
                </div>

            </div>
        </form>
    </div>

    <!-- RIGHT: PREVIEW -->
    <div class="right-panel">
        <div class="preview-topbar">
            <div class="preview-topbar-left">
                <i class="fa-regular fa-eye"></i>
                <span id="previewTemplateName">Resume Preview — Modern Professional</span>
            </div>
            <div class="zoom-controls">
                <button class="zoom-btn">−</button>
                <span>100%</span>
                <button class="zoom-btn">+</button>
            </div>
        </div>

        <div class="resume-paper-wrap">
            <div class="resume-paper" id="resumePaper">

                <div class="rv-name">@Model.Personal.FullName</div>
                <div class="rv-title">@Model.Personal.ProfessionalTitle</div>
                <div class="rv-contacts">
                    @if (!string.IsNullOrEmpty(Model.Personal.Email))
                    {
                        <span class="rv-contact-item"><i class="fa-regular fa-envelope"></i> @Model.Personal.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Phone))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-phone"></i> @Model.Personal.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Personal.Location))
                    {
                        <span class="rv-contact-item"><i class="fa-solid fa-location-dot"></i> @Model.Personal.Location</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Personal.Summary))
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Professional Summary</div>
                        <div class="rv-summary">@Model.Personal.Summary</div>
                    </div>
                }

                @if (Model.WorkExperiences.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Work Experience</div>
                        @foreach (var exp in Model.WorkExperiences)
                        {
                            <div class="rv-exp-item">
                                <div class="rv-exp-header">
                                    <div>
                                        <div class="rv-exp-title">@exp.JobTitle</div>
                                        <div class="rv-exp-company">@exp.Company</div>
                                    </div>
                                    <div class="rv-exp-date">@exp.StartDate — @(exp.IsCurrentJob ? "Present" : exp.EndDate)</div>
                                </div>
                                @if (!string.IsNullOrEmpty(exp.Description))
                                {
                                    <div class="rv-exp-desc">@exp.Description</div>
                                }
                            </div>
                        }
                    </div>
                }

                @if (Model.Educations.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Education</div>
                        @foreach (var edu in Model.Educations)
                        {
                            <div class="rv-edu-item">
                                <div class="rv-edu-header">
                                    <div>
                                        <div class="rv-edu-degree">@edu.Degree @(!string.IsNullOrEmpty(edu.FieldOfStudy) ? "in " + edu.FieldOfStudy : "")</div>
                                        <div class="rv-edu-school">@edu.School</div>
                                    </div>
                                    <div class="rv-edu-year">@edu.StartYear — @edu.EndYear</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (Model.Skills.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Skills</div>
                        <div class="rv-skills-wrap">
                            @foreach (var skill in Model.Skills)
                            {
                                <span class="rv-skill-tag">@skill</span>
                            }
                        </div>
                    </div>
                }

                @if (Model.Languages.Any())
                {
                    <div class="rv-section">
                        <div class="rv-section-title">Languages</div>
                        <div class="rv-lang-list">
                            @foreach (var lang in Model.Languages)
                            {
                                <div class="rv-lang-item">
                                    <div class="rv-lang-name">@lang.Name</div>
                                    <div class="rv-lang-prof">@lang.Proficiency</div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var templateColors = {
            'ModernProfessional': { primary: '#7C3AED', border: '#EDE9FE' },
            'ProfessionalBlue':   { primary: '#2563EB', border: '#DBEAFE' },
            'CreativeDesigner':   { primary: '#EA580C', border: '#FEE2E2' },
            'ExecutiveClassic':   { primary: '#374151', border: '#E5E7EB' },
            'MinimalClean':       { primary: '#059669', border: '#D1FAE5' },
            'AcademicScholar':    { primary: '#D97706', border: '#FEF3C7' },
            'BoldImpact':         { primary: '#DC2626', border: '#FEE2E2' },
            'ElegantClassic':     { primary: '#6D28D9', border: '#EDE9FE' },
        };

        var templateNames = {
            'ModernProfessional': 'Modern Professional',
            'ProfessionalBlue':   'Professional Blue',
            'CreativeDesigner':   'Creative Designer',
            'ExecutiveClassic':   'Executive Classic',
            'MinimalClean':       'Minimal Clean',
            'AcademicScholar':    'Academic Scholar',
            'BoldImpact':         'Bold Impact',
            'ElegantClassic':     'Elegant Classic',
        };

        // All resume data from session
                  var data = {
            name:     '@Html.Raw(Model.Personal.FullName?.Replace("'", "\\'"))',
            title:    '@Html.Raw(Model.Personal.ProfessionalTitle?.Replace("'", "\\'"))',
            email:    '@Html.Raw(Model.Personal.Email?.Replace("'", "\\'"))',
            phone:    '@Html.Raw(Model.Personal.Phone?.Replace("'", "\\'"))',
            location: '@Html.Raw(Model.Personal.Location?.Replace("'", "\\'"))',
            summary:  '@Html.Raw(Model.Personal.Summary?.Replace("'", "\\'").Replace("\r\n", " ").Replace("\n", " "))',
            skills:   @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Skills ?? new List<string>())),
            exps:     @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WorkExperiences ?? new List<Resume_Builder.Models.WorkExperience>())),
            edus:     @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Educations ?? new List<Resume_Builder.Models.Education>())),
            langs:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Languages ?? new List<Resume_Builder.Models.Language>())),
            certs:    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Certifications ?? new List<Resume_Builder.Models.Certification>())),
        };

        function selectTemplate(name, card) {
            document.querySelectorAll('.template-card').forEach(function(c) {
                c.classList.remove('selected');
            });
            card.classList.add('selected');
            document.getElementById('selectedTemplate').value = name;
            document.getElementById('previewTemplateName').textContent =
                'Resume Preview — ' + templateNames[name];
            renderPreview(name);
        }

        function renderPreview(name) {
            var paper = document.getElementById('resumePaper');
            var c = templateColors[name];

            if (name === 'ProfessionalBlue') {
                paper.innerHTML = getProfessionalBlue(c);
            } else if (name === 'CreativeDesigner') {
                paper.innerHTML = getCreativeDesigner(c);
            } else if (name === 'MinimalClean') {
                paper.innerHTML = getMinimalClean(c);
            } else if (name === 'ExecutiveClassic') {
                paper.innerHTML = getExecutiveClassic(c);
            } else if (name === 'AcademicScholar') {
                paper.innerHTML = getAcademicScholar(c);
            } else if (name === 'BoldImpact') {
                paper.innerHTML = getBoldImpact(c);
            } else if (name === 'ElegantClassic') {
                paper.innerHTML = getElegantClassic(c);
            } else {
                paper.innerHTML = getModernProfessional(c);
            }
        }

        // ── MODERN PROFESSIONAL ──────────────────────────
        function getModernProfessional(c) {
            var h = '';
            h += '<div style="border-bottom:3px solid ' + c.primary + ';padding-bottom:16px;margin-bottom:16px;">';
            h += '<div style="font-size:1.8rem;font-weight:700;color:#1E293B;">' + data.name + '</div>';
            h += '<div style="font-size:1rem;color:' + c.primary + ';font-weight:500;margin-top:4px;">' + data.title + '</div>';
            h += '<div style="display:flex;gap:16px;margin-top:10px;flex-wrap:wrap;">';
            if (data.email) h += '<span style="font-size:0.78rem;color:#64748B;"><i class="fa-regular fa-envelope" style="color:' + c.primary + '"></i> ' + data.email + '</span>';
            if (data.phone) h += '<span style="font-size:0.78rem;color:#64748B;"><i class="fa-solid fa-phone" style="color:' + c.primary + '"></i> ' + data.phone + '</span>';
            if (data.location) h += '<span style="font-size:0.78rem;color:#64748B;"><i class="fa-solid fa-location-dot" style="color:' + c.primary + '"></i> ' + data.location + '</span>';
            h += '</div></div>';
            if (data.summary) {
                h += section('Professional Summary', c);
                h += '<p style="font-size:0.82rem;color:#64748B;line-height:1.6;">' + data.summary + '</p>';
            }
            h += expSection(c);
            h += eduSection(c);
            h += skillsSection(c);
            h += langsSection(c);
            return h;
        }

