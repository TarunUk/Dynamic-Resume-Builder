                h += '<div style="font-size:0.75rem;font-weight:700;color:' + c.primary + ';text-transform:uppercase;margin-bottom:8px;border-bottom:2px solid ' + c.primary + ';padding-bottom:4px;">Education</div>';
                data.edus.forEach(function(e) {
                    h += '<div style="margin-bottom:10px;">';
