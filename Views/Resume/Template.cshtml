        // ── SHARED SECTION HELPERS ───────────────────────
        function section(title, c) {
            return '<div style="font-size:0.75rem;font-weight:700;color:' + c.primary + ';text-transform:uppercase;letter-spacing:0.08em;margin:14px 0 6px;border-bottom:1px solid #EDE9FE;padding-bottom:4px;">' + title + '</div>';
        }
        function expSection(c) {
            if (!data.exps.length) return '';
            var h = section('Work Experience', c);
            data.exps.forEach(function(e) {
                h += '<div style="margin-bottom:12px;">';
                h += '<div style="display:flex;justify-content:space-between;">';
                h += '<span style="font-size:0.88rem;font-weight:600;color:#1E293B;">' + e.JobTitle + '</span>';
                h += '<span style="font-size:0.72rem;color:#64748B;">' + e.StartDate + ' – ' + (e.IsCurrentJob ? 'Present' : e.EndDate) + '</span>';
                h += '</div>';
                h += '<div style="font-size:0.78rem;color:' + c.primary + ';">' + e.Company + '</div>';
                if (e.Description) h += '<div style="font-size:0.75rem;color:#64748B;margin-top:3px;">• ' + e.Description.substring(0,120) + '</div>';
                h += '</div>';
            });
            return h;
        }
        function eduSection(c) {
            if (!data.edus.length) return '';
            var h = section('Education', c);
            data.edus.forEach(function(e) {
                h += '<div style="margin-bottom:10px;display:flex;justify-content:space-between;">';
                h += '<div><div style="font-size:0.88rem;font-weight:600;color:#1E293B;">' + e.Degree + (e.FieldOfStudy ? ' in ' + e.FieldOfStudy : '') + '</div>';
                h += '<div style="font-size:0.78rem;color:' + c.primary + ';">' + e.School + '</div></div>';
                h += '<div style="font-size:0.75rem;color:#64748B;">' + e.StartYear + ' – ' + e.EndYear + '</div>';
                h += '</div>';
            });
            return h;
        }
        function skillsSection(c) {
            if (!data.skills.length) return '';
            var h = section('Skills', c);
            h += '<div style="display:flex;flex-wrap:wrap;gap:6px;">';
            data.skills.forEach(function(s) {
                h += '<span style="background:#EDE9FE;color:' + c.primary + ';padding:4px 10px;border-radius:12px;font-size:0.75rem;font-weight:500;">' + s + '</span>';
            });
            h += '</div>';
            return h;
        }
        function langsSection(c) {
            if (!data.langs.length) return '';
            var h = section('Languages', c);
            h += '<div style="display:flex;flex-wrap:wrap;gap:8px;">';
            data.langs.forEach(function(l) {
                h += '<div style="background:#F8FAFC;border:1px solid #E2E8F0;border-radius:8px;padding:5px 12px;text-align:center;">';
                h += '<div style="font-size:0.8rem;font-weight:600;color:#1E293B;">' + l.Name + '</div>';
                h += '<div style="font-size:0.7rem;color:' + c.primary + ';">' + l.Proficiency + '</div>';
                h += '</div>';
            });
            h += '</div>';
            return h;
        }

        // Load default on page load
        window.onload = function() {
            renderPreview('ModernProfessional');
        }
    </script>
